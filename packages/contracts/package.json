{
  "name": "@careero/contracts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "generated",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:json-schema": "tsx scripts/generate-json-schema.ts",
    "test": "npm run generate:json-schema && vitest run",
    "validate": "npm run build && npm run generate:json-schema && npm run test"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6",
    "zod-to-json-schema": "^3.25.0"
  }
}
