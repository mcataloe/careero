{
  "$ref": "#/definitions/Opportunity",
  "definitions": {
    "Opportunity": {
      "type": "object",
      "properties": {
        "contractVersion": {
          "type": "string",
          "const": "careero.contracts.v1"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "$ref": "#/definitions/Opportunity/properties/createdAt"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "$ref": "#/definitions/Opportunity/properties/id"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "manual",
            "linkedin_manual",
            "greenhouse",
            "lever",
            "ashby",
            "workable",
            "company_site",
            "recruiter_email",
            "job_board",
            "referral",
            "other"
          ]
        },
        "sourceUrl": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "rawContent": {
          "type": [
            "string",
            "null"
          ]
        },
        "normalizedContent": {
          "type": "object",
          "properties": {
            "description": {
              "type": [
                "string",
                "null"
              ]
            },
            "responsibilities": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "requirements": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "seniority": {
              "type": [
                "string",
                "null"
              ]
            },
            "notes": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "description",
            "seniority",
            "notes"
          ],
          "additionalProperties": false
        },
        "company": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "websiteUrl": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Opportunity/properties/sourceUrl/anyOf/0"
                },
                {
                  "type": "null"
                }
              ]
            },
            "industry": {
              "type": [
                "string",
                "null"
              ]
            },
            "notes": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "name",
            "websiteUrl",
            "industry",
            "notes"
          ],
          "additionalProperties": false
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "employmentType": {
          "type": "string",
          "enum": [
            "full_time",
            "part_time",
            "contract",
            "consulting",
            "fractional",
            "internship",
            "temporary",
            "other",
            "unspecified"
          ]
        },
        "compensation": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "min": {
                  "anyOf": [
                    {
                      "type": "number",
                      "minimum": 0
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "max": {
                  "anyOf": [
                    {
                      "type": "number",
                      "minimum": 0
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "currency": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 3,
                      "maxLength": 3
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "period": {
                  "anyOf": [
                    {
                      "type": "string",
                      "enum": [
                        "hourly",
                        "daily",
                        "weekly",
                        "monthly",
                        "annual",
                        "project"
                      ]
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "sourceText": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "min",
                "max",
                "currency",
                "period",
                "sourceText"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        },
        "location": {
          "type": "object",
          "properties": {
            "label": {
              "type": [
                "string",
                "null"
              ]
            },
            "city": {
              "type": [
                "string",
                "null"
              ]
            },
            "region": {
              "type": [
                "string",
                "null"
              ]
            },
            "country": {
              "type": [
                "string",
                "null"
              ]
            },
            "timezone": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "label",
            "city",
            "region",
            "country",
            "timezone"
          ],
          "additionalProperties": false
        },
        "remoteMode": {
          "type": "string",
          "enum": [
            "remote",
            "hybrid",
            "onsite",
            "unspecified"
          ]
        },
        "parseConfidence": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "default": {}
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "default": []
        },
        "status": {
          "type": "string",
          "enum": [
            "discovered",
            "interested",
            "evaluating",
            "evaluated",
            "application_started",
            "applied",
            "rejected",
            "withdrawn",
            "archived"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "contractVersion",
        "createdAt",
        "updatedAt",
        "id",
        "workspaceId",
        "sourceType",
        "sourceUrl",
        "rawContent",
        "normalizedContent",
        "company",
        "title",
        "employmentType",
        "compensation",
        "location",
        "remoteMode",
        "status",
        "metadata"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
