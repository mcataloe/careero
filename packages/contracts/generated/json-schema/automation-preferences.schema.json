{
  "$ref": "#/definitions/AutomationPreferences",
  "definitions": {
    "AutomationPreferences": {
      "type": "object",
      "properties": {
        "contractVersion": {
          "type": "string",
          "const": "careero.contracts.v1"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "$ref": "#/definitions/AutomationPreferences/properties/createdAt"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "$ref": "#/definitions/AutomationPreferences/properties/id"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "suggestionCategories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "follow_up_suggestion",
              "reminder_suggestion",
              "artifact_readiness_check",
              "communication_draft",
              "workflow_state_suggestion",
              "opportunity_review_suggestion",
              "future_external_action_disabled"
            ]
          },
          "default": []
        },
        "followUpSuggestionDays": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 7
        },
        "artifactReadinessChecksEnabled": {
          "type": "boolean",
          "default": true
        },
        "communicationDraftsEnabled": {
          "type": "boolean",
          "default": true
        },
        "internalStateChangeSuggestionsEnabled": {
          "type": "boolean",
          "default": true
        },
        "futureExternalActionsEnabled": {
          "type": "boolean",
          "const": false
        },
        "quietMode": {
          "type": "boolean",
          "default": false
        },
        "policyVersion": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "contractVersion",
        "createdAt",
        "updatedAt",
        "id",
        "workspaceId",
        "futureExternalActionsEnabled",
        "policyVersion",
        "metadata"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
